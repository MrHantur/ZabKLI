<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="8dp">

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/olympiad"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        
        android:padding="16dp"
        app:strokeWidth="1dp"
        app:strokeColor="#1A000000"
        app:cardCornerRadius="16dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"

            android:paddingEnd="8dp"
            android:paddingTop="8dp"
            android:paddingBottom="8dp">

            <TextView
                android:id="@+id/olympiadName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="Olympiad name"
                android:paddingStart="4dp"
                android:textSize="20sp"
                android:textStyle="bold" />

            <com.google.android.flexbox.FlexboxLayout
                android:id="@+id/flexTags"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                app:flexDirection="row"
                app:flexWrap="wrap"
                app:alignItems="center"
                app:justifyContent="flex_start">

                <TextView
                    android:id="@+id/tagSubject"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:layout_marginTop="8dp"
                    android:paddingHorizontal="14dp"
                    android:paddingVertical="6dp"
                    android:text="Subject"
                    android:textColor="@android:color/white"
                    android:background="@drawable/tag_green"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tagClasses"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:layout_marginTop="8dp"
                    android:paddingHorizontal="14dp"
                    android:paddingVertical="6dp"
                    android:text="Classes"
                    android:textColor="@android:color/black"
                    android:background="@drawable/tag_purple"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tagDate"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:layout_marginTop="8dp"
                    android:paddingHorizontal="14dp"
                    android:paddingVertical="6dp"
                    android:text="Date"
                    android:textColor="@android:color/black"
                    android:background="@drawable/tag_blue"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tagTime"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:layout_marginTop="8dp"
                    android:paddingHorizontal="14dp"
                    android:paddingVertical="6dp"
                    android:text="Time"
                    android:textColor="@android:color/white"
                    android:background="@drawable/tag_grey"
                    android:textStyle="bold" />

            </com.google.android.flexbox.FlexboxLayout>

        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>

</androidx.constraintlayout.widget.ConstraintLayout>