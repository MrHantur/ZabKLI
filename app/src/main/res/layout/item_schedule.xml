<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="4dp">

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/lessonCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="4dp"
        app:cardCornerRadius="16dp"
        app:strokeWidth="2dp"
        app:strokeColor="#1A000000"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="12dp"
            android:paddingBottom="12dp">

            <!-- Номер урока -->
            <TextView
                android:id="@+id/lessonNum"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_gravity="center_vertical"
                android:background="@drawable/tag_purple"
                android:gravity="center"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@android:color/black"
                tools:text="1" />

            <!-- Данные урока -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="12dp"
                android:orientation="vertical">

                <!-- Название предмета -->
                <TextView
                    android:id="@+id/subjectName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="17sp"
                    android:textStyle="bold"
                    android:paddingStart="2dp"
                    android:textColor="?attr/colorOnSurface"
                    tools:text="Математика" />

                <!-- Время урока -->
                <TextView
                    android:id="@+id/lessonTime"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:layout_marginStart="2dp"
                    android:textAppearance="?attr/textAppearanceBody2"
                    android:textColor="?android:attr/textColorSecondary"
                    tools:text="08:00 – 08:45" />

                <!-- Теги: учитель + кабинет + статус -->
                <com.google.android.flexbox.FlexboxLayout
                    android:id="@+id/flexTags"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"

                    app:flexDirection="row"
                    app:flexWrap="wrap"
                    app:alignItems="center"
                    app:justifyContent="flex_start">

                        <!-- Статус "ОТМЕНЁН" -->
                        <TextView
                            android:id="@+id/lessonStatus"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:paddingHorizontal="12dp"
                            android:paddingVertical="4dp"
                            android:layout_marginTop="4dp"
                            android:textColor="@android:color/white"
                            android:background="@drawable/tag_red"
                            android:textStyle="bold"
                            android:textSize="12sp"
                            android:visibility="gone"
                            android:text="ОТМЕНЁН"
                            tools:visibility="visible" />

                        <TextView
                            android:id="@+id/teacherName"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="6dp"
                            android:paddingHorizontal="12dp"
                            android:paddingVertical="4dp"
                            android:layout_marginTop="4dp"
                            android:textColor="@android:color/white"
                            android:background="@drawable/tag_green"
                            android:textStyle="bold"
                            android:textSize="12sp"
                            android:visibility="gone"
                            tools:text="Teacher"
                            tools:visibility="visible" />

                        <TextView
                            android:id="@+id/roomNumber"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="6dp"
                            android:paddingHorizontal="12dp"
                            android:paddingVertical="4dp"
                            android:layout_marginTop="4dp"
                            android:textColor="@android:color/black"
                            android:background="@drawable/tag_blue"
                            android:textStyle="bold"
                            android:textSize="12sp"
                            android:visibility="gone"
                            tools:text="Каб. 214"
                            tools:visibility="visible" />

                </com.google.android.flexbox.FlexboxLayout>
            </LinearLayout>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>
</androidx.constraintlayout.widget.ConstraintLayout>