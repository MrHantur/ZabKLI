<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    tools:context=".ui.olympiads.OlympiadsFragment">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <LinearLayout
            android:id="@+id/filterContainer"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:paddingTop="8dp"
            android:gravity="center_vertical"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <!-- Кнопка выбора предмета -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/buttonSubject"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Предмет"
                app:icon="@drawable/ic_category"
                app:iconGravity="textStart"
                app:iconPadding="8dp"
                app:iconTint="?attr/colorPrimary" />

            <!-- Отступ между кнопками -->
            <Space
                android:layout_width="12dp"
                android:layout_height="0dp" />

            <!-- Кнопка сортировки -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/buttonSort"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Сортировка"
                app:icon="@drawable/ic_sort"
                app:iconGravity="textStart"
                app:iconPadding="8dp"
                app:iconTint="?attr/colorPrimary" />

        </LinearLayout>

        <!-- Список олимпиад -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerView"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_marginEnd="8dp"
            android:layout_marginTop="8dp"
            android:nestedScrollingEnabled="false"
            app:layout_constraintTop_toBottomOf="@id/filterContainer"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            tools:listitem="@layout/item_olympiad"/>

        <!-- Ошибки (оверлеи, позиционируются относительно родительского ConstraintLayout) -->

        <!--
            FIX 3: высота изменена с 0dp на wrap_content + minHeight.
            При 0dp с двусторонними вертикальными констрейнтами (top_toTopOf + bottom_toBottomOf)
            в родителе с layout_height="wrap_content" возникает циклическая зависимость,
            и итоговая высота оказывается 0 — вьюхи невидимы даже при VISIBLE.
        -->
        <LinearLayout
            android:id="@+id/errorNoInternet"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:minHeight="300dp"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="16dp"
            android:visibility="gone"
            android:background="@android:color/white"
            app:layout_constraintTop_toBottomOf="@id/filterContainer"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">
            <ImageView
                android:id="@+id/noInternet"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@drawable/cat_no_internet" />
            <TextView
                android:id="@+id/text_no_internet"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/error_no_internet"
                android:textAppearance="?attr/textAppearanceHeadline6"
                android:gravity="center"
                android:layout_marginTop="16dp" />
        </LinearLayout>

        <!-- FIX 3: аналогично -->
        <LinearLayout
            android:id="@+id/errorServer"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:minHeight="300dp"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="16dp"
            android:visibility="gone"
            android:background="@android:color/white"
            app:layout_constraintTop_toBottomOf="@id/filterContainer"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">
            <ImageView
                android:id="@+id/serverProblem"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@drawable/cat_server_problem" />
            <TextView
                android:id="@+id/textServerProblem"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/error_server_problem"
                android:textAppearance="?attr/textAppearanceHeadline6"
                android:gravity="center"
                android:layout_marginTop="16dp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/errorNoOlymp"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:minHeight="200dp"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="16dp"
            android:visibility="gone"
            app:layout_constraintTop_toBottomOf="@id/filterContainer"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">
            <ImageView
                android:id="@+id/noOlymp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@drawable/cat_no_olymp" />
            <TextView
                android:id="@+id/textNoOlymp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/error_no_olymp"
                android:textAppearance="?attr/textAppearanceHeadline6"
                android:gravity="center"
                android:layout_marginTop="16dp" />
        </LinearLayout>

        <!-- FIX 3: аналогично -->
        <LinearLayout
            android:id="@+id/errorUnknown"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:minHeight="300dp"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="16dp"
            android:visibility="gone"
            android:background="@android:color/white"
            app:layout_constraintTop_toBottomOf="@id/filterContainer"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">
            <ImageView
                android:id="@+id/unknown"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@drawable/cat_unknown" />
            <TextView
                android:id="@+id/textUnknown"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/error_unknown"
                android:textAppearance="?attr/textAppearanceHeadline6"
                android:gravity="center"
                android:layout_marginTop="16dp" />
            <TextView
                android:id="@+id/textForReport"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/error_unknown_placeholder"
                android:textAppearance="?attr/textAppearanceHeadline6"
                android:gravity="center"
                android:layout_marginTop="16dp" />
        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.core.widget.NestedScrollView>